# Copy to web/.env for local dev, or set the same names in Netlify → Environment variables.
# Preview deploys need these too, and the preview URL must be in Supabase Auth → Redirect URLs.

VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY
VITE_AUTH_REDIRECT_URL=http://localhost:5173/
